//
// Smoke test: build and run the yolo26n-cls m0 (3x3 stride-2 INT8 stem) on
// the NPU2 and bit-exact compare vs ONNX Runtime's post-SiLU /model.0/act
// tensor.
//
// REQUIRES: ryzen_ai_npu2, peano
//
// RUN: mkdir -p %t.work
// RUN: cd %t.work
// RUN: make -f %S/Makefile clean
// RUN: make -f %S/Makefile data BLOCK=m0
// RUN: %run_on_npu2% make -f %S/Makefile run_ort BLOCK=m0
