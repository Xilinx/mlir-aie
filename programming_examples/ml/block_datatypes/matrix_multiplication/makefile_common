include ${srcdir}/../../../../makefile-common

matrix_multiplication_dir := ${srcdir}/../../../../basic/matrix_multiplication

aieargs+=-d ${devicename} -m $m -k $k -n $n -M $M -K $K -N $N
target_suffix?=${M}x${K}x${N}_${m}x${k}x${n}

xclbin_target?=build/final_${target_suffix}.xclbin
insts_target?=build/insts_${target_suffix}.bin
aie_py_src?=${targetname}.py

runargs?=-v 2 --warmup 1 --iters 1

# ##########################################################################
# Targets
# ##########################################################################

.PHONY: all
all: ${xclbin_target} ${insts_target} ${targetname}.exe

# @iron.jit's compile() drives kernel compilation (xchesscc for the
# bfp16 mac kernels — Peano's AIE2P backend can't yet legalize them);
# the python invocation produces the xclbin + insts.bin in one step.
${xclbin_target} ${insts_target} &: ${srcdir}/${aie_py_src}
	mkdir -p $$(dirname ${xclbin_target})
	python3 $< ${aieargs} --xclbin-path=${xclbin_target} --insts-path=${insts_target}

${targetname}.exe: ${hostsrc} ${matrix_multiplication_dir}/common.h ${srcdir}/../../helper.h
	rm -rf _build
	mkdir -p _build
	cd _build && ${powershell} cmake -E env CXXFLAGS="-std=c++23 -ggdb -DDTYPE_IN=${dtype_in_cpp} -DDTYPE_OUT=${dtype_out_cpp} -DDTYPE_ACC=${dtype_acc_cpp}" \
		cmake `${getwslpath} ${srcdir}/..` -D CMAKE_C_COMPILER=${CC} -D CMAKE_CXX_COMPILER=${CXX} -DTARGET_NAME=${targetname} -DHOST_SRC=${hostsrc} -DMATMUL_DIR=${matrix_multiplication_dir}
	cd _build && ${powershell} cmake --build . --config Release
ifeq "${powershell}" "powershell.exe"
	cp _build/${targetname}.exe $@
else
	cp _build/${targetname} $@
endif

run: ${targetname}.exe ${xclbin_target} ${insts_target}
	${powershell} ./$< -x ${xclbin_target} -i ${insts_target} -k MLIR_AIE -M $M -K $K -N $N -w $m -y $k -z $n ${runargs}

.PHONY: clean
clean:
	rm -rf build _build ${targetname}.exe
