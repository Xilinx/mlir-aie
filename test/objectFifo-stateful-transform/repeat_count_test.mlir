// CHECK:               %[[VAL_32:.*]] = arith.maxsi %[[VAL_31]], %[[VAL_30]] : i32
// CHECK:               aie.use_lock(%[[VAL_11]], AcquireGreaterEqual, %[[VAL_32]])
