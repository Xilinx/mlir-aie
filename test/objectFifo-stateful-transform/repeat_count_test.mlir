// CHECK:             aie.end
// CHECK:           }
// CHECK:           %[[VAL_57:.*]] = aie.memtile_dma(%[[VAL_0]]) {
// CHECK:             %[[VAL_58:.*]] = aie.dma_start(MM2S, 0, ^bb1, ^bb2)
// CHECK:           ^bb1:
// CHECK:             %[[VAL_59:.*]] = arith.constant 1 : i32
// CHECK:             aie.use_lock(%[[VAL_14]], AcquireGreaterEqual, %[[VAL_59]])
