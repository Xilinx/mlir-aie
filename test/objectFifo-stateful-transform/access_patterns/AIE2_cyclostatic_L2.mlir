// CHECK:           %[[VAL_7:.*]] = aie.lock(%[[VAL_2]], 0) {init = 4 : i32, sym_name = "fifo1_cons_prod_lock_0"}
// CHECK:           %[[VAL_8:.*]] = aie.lock(%[[VAL_2]], 1) {init = 0 : i32, sym_name = "fifo1_cons_cons_lock_0"}
// CHECK:           %[[VAL_9:.*]] = aie.buffer(%[[VAL_1]]) {sym_name = "fifo0_cons_buff_0"} : memref<1xi32>
