// CHECK:             aie.use_lock(%[[VAL_17]], AcquireGreaterEqual, %[[VAL_21]])
// CHECK:             memref.store %[[VAL_22]], %[[VAL_16]]{{\[}}%[[VAL_26]]] : memref<1xi32>
// CHECK:             aie.use_lock(%[[VAL_18]], Release, %[[VAL_21]])
