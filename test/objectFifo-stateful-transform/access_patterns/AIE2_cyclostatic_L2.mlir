// CHECK:           %[[VAL_45:.*]] = aie.mem(%[[VAL_2]]) {
// CHECK:             %[[VAL_46:.*]] = arith.constant 1 : i32
// CHECK:             %[[VAL_47:.*]] = aie.dma_start(S2MM, 0, ^bb1, ^bb5)
// CHECK:           ^bb1:
// CHECK:             aie.use_lock(%[[VAL_7]], AcquireGreaterEqual, %[[VAL_46]])
