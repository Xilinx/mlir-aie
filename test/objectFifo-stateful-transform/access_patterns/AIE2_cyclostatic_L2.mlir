// CHECK:           %[[VAL_27:.*]] = aie.core(%[[VAL_2]]) {
// CHECK:             %[[VAL_28:.*]] = arith.constant 1 : i32
// CHECK:             %[[VAL_29:.*]] = arith.constant 3 : index
// CHECK:             %[[VAL_30:.*]] = arith.constant 2 : index
