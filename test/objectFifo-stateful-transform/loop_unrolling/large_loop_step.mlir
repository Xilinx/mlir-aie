// CHECK:               aie.use_lock(%[[VAL_6]], Acquire, %[[VAL_16]])
// CHECK:               func.call @some_work(%[[VAL_2]], %[[VAL_22]]) : (memref<16xi32>, index) -> ()
// CHECK:               aie.use_lock(%[[VAL_6]], Release, %[[VAL_17]])
