// CHECK-LABEL:   aie.device(npu1_1col) {
// CHECK:           %[[VAL_0:.*]] = aie.tile(0, 2)
// CHECK:           %[[VAL_1:.*]] = aie.tile(0, 3)
// CHECK:           %[[VAL_2:.*]] = aie.buffer(%[[VAL_0]]) {sym_name = "of_2_buff_0"} : memref<16xi32>
// CHECK:           %[[VAL_3:.*]] = aie.lock(%[[VAL_0]], 0) {init = 1 : i32, sym_name = "of_2_prod_lock_0"}
// CHECK:           %[[VAL_4:.*]] = aie.lock(%[[VAL_0]], 1) {init = 0 : i32, sym_name = "of_2_cons_lock_0"}
// CHECK:           %[[VAL_5:.*]] = aie.buffer(%[[VAL_1]]) {sym_name = "of_1_buff_0"} : memref<16xi32>
// CHECK:           %[[VAL_6:.*]] = aie.lock(%[[VAL_1]], 0) {init = 1 : i32, sym_name = "of_1_prod_lock_0"}
// CHECK:           %[[VAL_7:.*]] = aie.lock(%[[VAL_1]], 1) {init = 0 : i32, sym_name = "of_1_cons_lock_0"}
// CHECK:           func.func @some_work(%[[VAL_8:.*]]: memref<16xi32>, %[[VAL_9:.*]]: memref<16xi32>, %[[VAL_10:.*]]: index, %[[VAL_11:.*]]: index) {
// CHECK:             return
// CHECK:           }
// CHECK:           %[[VAL_12:.*]] = aie.core(%[[VAL_0]]) {
// CHECK:             %[[VAL_13:.*]] = arith.constant 13 : index
// CHECK:             %[[VAL_14:.*]] = arith.constant 12 : index
// CHECK:             %[[VAL_15:.*]] = arith.constant 1 : index
// CHECK:             %[[VAL_16:.*]] = arith.constant 0 : index
// CHECK:             %[[VAL_17:.*]] = arith.constant 1 : i32
// CHECK:             scf.for %[[VAL_18:.*]] = %[[VAL_16]] to %[[VAL_14]] step %[[VAL_15]] {
// CHECK:               scf.for %[[VAL_19:.*]] = %[[VAL_16]] to %[[VAL_13]] step %[[VAL_15]] {
// CHECK:                 aie.use_lock(%[[VAL_7]], AcquireGreaterEqual, %[[VAL_17]])
// CHECK:                 scf.for %[[VAL_20:.*]] = %[[VAL_16]] to %[[VAL_13]] step %[[VAL_15]] {
// CHECK:                   aie.use_lock(%[[VAL_3]], AcquireGreaterEqual, %[[VAL_17]])
// CHECK:                   func.call @some_work(%[[VAL_5]], %[[VAL_2]], %[[VAL_18]], %[[VAL_19]]) : (memref<16xi32>, memref<16xi32>, index, index) -> ()
// CHECK:                   aie.use_lock(%[[VAL_4]], Release, %[[VAL_17]])
// CHECK:                 }
// CHECK:                 aie.use_lock(%[[VAL_6]], Release, %[[VAL_17]])
// CHECK:               }
// CHECK:             }
// CHECK:             scf.for %[[VAL_21:.*]] = %[[VAL_16]] to %[[VAL_13]] step %[[VAL_15]] {
// CHECK:               aie.use_lock(%[[VAL_7]], AcquireGreaterEqual, %[[VAL_17]])
// CHECK:               scf.for %[[VAL_22:.*]] = %[[VAL_16]] to %[[VAL_13]] step %[[VAL_15]] {
// CHECK:                 aie.use_lock(%[[VAL_3]], AcquireGreaterEqual, %[[VAL_17]])
// CHECK:                 func.call @some_work(%[[VAL_5]], %[[VAL_2]], %[[VAL_16]], %[[VAL_21]]) : (memref<16xi32>, memref<16xi32>, index, index) -> ()
// CHECK:                 aie.use_lock(%[[VAL_4]], Release, %[[VAL_17]])
// CHECK:               }
// CHECK:               aie.use_lock(%[[VAL_6]], Release, %[[VAL_17]])
// CHECK:             }
// CHECK:             aie.end
// CHECK:           }
// CHECK:         }

module {
  aie.device(npu1_1col) {
    %tile12 = aie.tile(0, 2)
    %tile13 = aie.tile(0, 3)
    aie.objectfifo @of_1 (%tile13, {%tile12}, 1 : i32) : !aie.objectfifo<memref<16xi32>>
    aie.objectfifo @of_2 (%tile12, {%tile13}, 1 : i32) : !aie.objectfifo<memref<16xi32>>
    func.func @some_work(%line_inA:memref<16xi32>, %line_inB:memref<16xi32>, %indexH:index, %indexW:index) -> () {
      return
    }
    %core12 = aie.core(%tile12) {
      %c0 = arith.constant 0 : index
      %c1 = arith.constant 1 : index
      %c12 = arith.constant 12 : index
      %c13 = arith.constant 13 : index

      scf.for %indexInHeight = %c0 to %c12 step %c1 {

        scf.for %indexInWidth = %c0 to %c13 step %c1 {
          %subviewIn = aie.objectfifo.acquire @of_1 (Consume, 1) : !aie.objectfifosubview<memref<16xi32>>

          scf.for %i = %c0 to %c13 step %c1 {
            %subviewOut = aie.objectfifo.acquire @of_2 (Produce, 1) : !aie.objectfifosubview<memref<16xi32>>
            %elemIn = aie.objectfifo.subview.access %subviewIn[0] : !aie.objectfifosubview<memref<16xi32>> -> memref<16xi32>
            %elemOut = aie.objectfifo.subview.access %subviewOut[0] : !aie.objectfifosubview<memref<16xi32>> -> memref<16xi32>
            func.call @some_work(%elemIn, %elemOut, %indexInHeight, %indexInWidth) : (memref<16xi32>, memref<16xi32>, index, index) -> ()
            aie.objectfifo.release @of_2 (Produce, 1)
          }

          aie.objectfifo.release @of_1 (Consume, 1)
        }
      }

      scf.for %indexInWidth = %c0 to %c13 step %c1 {
        %subviewIn1 = aie.objectfifo.acquire @of_1 (Consume, 1) : !aie.objectfifosubview<memref<16xi32>>

        scf.for %i = %c0 to %c13 step %c1 {
          %subviewOut1 = aie.objectfifo.acquire @of_2 (Produce, 1) : !aie.objectfifosubview<memref<16xi32>>
          %elemIn = aie.objectfifo.subview.access %subviewIn1[0] : !aie.objectfifosubview<memref<16xi32>> -> memref<16xi32>
          %elemOut = aie.objectfifo.subview.access %subviewOut1[0] : !aie.objectfifosubview<memref<16xi32>> -> memref<16xi32>
          func.call @some_work(%elemIn, %elemOut, %c0, %indexInWidth) : (memref<16xi32>, memref<16xi32>, index, index) -> ()
          aie.objectfifo.release @of_2 (Produce, 1)
        }

        aie.objectfifo.release @of_1 (Consume, 1)
      }

      aie.end
    }
  }
}
