//
// REQUIRES: ryzen_ai_npu2, peano
//
// Regression test for mlir-aie issue #2579 — buffer alignment on NPU2.
//
// stack_size = 1028 (set on aie.core in aie.mlir) intentionally puts the
// stack-end on a non-64B boundary.  The compute-tile kernel does
// aie::load_v<int32_t,16> (a 512-bit aligned load that requires 64B
// alignment on AIE2P).  Pre-fix the allocator only padded to 32B and the
// load returned wrong data; the fix overrides
// getComputeTileLoadStoreBusWidth() = 512 on BaseNPU2TargetModel.
//
// RUN: %PEANO_INSTALL_DIR/bin/clang++ --target=aie2p-none-unknown-elf -O2 -std=c++20 -I %aietools/include -c %S/kernel.cc -o ./kernel.o
// RUN: aiecc --no-xchesscc --no-xbridge --aie-generate-xclbin --xclbin-name=aie.xclbin --aie-generate-npu-insts --npu-insts-name=insts.bin %S/aie.mlir
// RUN: clang %S/test.cpp -o test.exe -std=c++17 -Wall %xrt_flags -lrt -lstdc++ %test_utils_flags
// RUN: ./test.exe -x aie.xclbin -k MLIR_AIE -i insts.bin
